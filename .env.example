# Database (PostgreSQL via Supabase/Neon or local)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/finance_app

# SQLite alternative for local dev (uncomment to use)
# DATABASE_URL=sqlite+aiosqlite:///./finance_app.db

# App settings
APP_ENV=development
SECRET_KEY=change-me-in-production-use-strong-random-key

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# API settings
API_PREFIX=/api/v1
DEBUG=true
